' --- RELACIONES DE HERENCIA Y ESTRUCTURA ---
java.lang.Thread <|-- PA.Child
java.lang.Thread <|-- PA.Demogorgon
java.lang.Thread <|-- PA.ManejadorCliente
javax.swing.JFrame <|-- PA.GUI
javax.swing.JFrame <|-- PA.ModuloRemoto
PA.ServidorSockets +-- PA.ManejadorCliente
PA.Zona +-- PA.TipoZona

' --- RELACIONES DEL SISTEMA CENTRAL ---
PA.Sistemageneral *-- "7" PA.Zona : gestiona
PA.Sistemageneral *-- "4" PA.Portal : controla
PA.Sistemageneral *-- PA.Colmena : posee
PA.Sistemageneral o-- "many" PA.Demogorgon : coordina
PA.Sistemageneral ..> PA.Child : crea hilos

' --- INTERACCIONES DE LOS HILOS ---
PA.Child --> PA.Sistemageneral : consulta pausa
PA.Child --> PA.Zona : reside en
PA.Child ..> PA.Portal : solicita cruce

PA.Demogorgon --> PA.Sistemageneral : informa capturas
PA.Demogorgon --> PA.Zona : caza en
PA.Demogorgon ..> PA.Colmena : deposita victimas

' --- COMUNICACIÓN Y LOGS ---
PA.ServidorSockets --> PA.Sistemageneral : monitorea
PA.ManejadorCliente --> PA.Sistemageneral : consulta estado
PA.GUI --> PA.Sistemageneral : visualiza
PA.Logger "1" --o "*" PA.Sistemageneral : registra eventos





@enduml